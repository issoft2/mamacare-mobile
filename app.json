{
  "expo": {
    "name": "MumCare Assistant",
    "slug": "MumCare-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mumcarelogo.png",
    "scheme": "mumcare",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/mumlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A2E4A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mumcare.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "MumCare uses notifications for daily reminders, appointments, and important pregnancy updates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/mumcaresplash.png",
        "backgroundColor": "#1A2E4A"
      },
      "package": "com.mumcare.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/mumcarelogo.png",
      "name": "MumCare Assistant",
      "shortName": "MumCare",
      "themeColor": "#1A2E4A",
      "backgroundColor": "#FFF8F4"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "fddb02b4-179b-4cf3-9cc8-afc29f1d228e"
      }
    },
    "sdkVersion": "54.0.0"
  }
}
