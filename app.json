{
  "expo": {
    "name": "safeborn Assistant",
    "slug": "safeborn-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/safebornlogo.png",
    "scheme": "safeborn",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/safebornlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A2E4A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safeborn.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "safeborn uses notifications for daily reminders, appointments, and important pregnancy updates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/safebornsplash.png",
        "backgroundColor": "#1A2E4A"
      },
      "package": "com.safeborn.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/safebornlogo.png",
      "name": "safeborn Assistant",
      "shortName": "safeborn",
      "themeColor": "#1A2E4A",
      "backgroundColor": "#FFF8F4"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://safeborn.app/"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "sdkVersion": "54.0.0",
    "extra": {
      "router": {
        "origin": "https://safeborn.app/"
      },
      "eas": {
        "projectId": "e9e3f0bd-b8f9-41ef-83d9-992975318884"
      }
    }
  }
}
