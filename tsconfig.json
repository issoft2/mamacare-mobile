{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@mumcare/types": [
        "../packages/types/src/index.ts"
      ],
      "@mumcare/api": [
        "../packages/api/src/index.ts"
      ],
      "@mumcare/ui": [
        "../packages/ui/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
